# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Embedding Model
EMBEDDING_MODEL=text-embedding-3-small

# ChromaDB Storage
CHROMA_PERSIST_DIR=./chroma_db

# Text Chunking
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# Retrieval Settings
TOP_K=5
SIMILARITY_THRESHOLD=0.7

# Reranking
RERANK_ENABLED=True
